{
  "expo": {
    "name": "comer-o-que",
    "slug": "comer-o-que",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ComerOQue/app-icon-comer-o-que.png",
    "scheme": "comeroque",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F0000A",
          "image": "./assets/images/ComerOQue/splash-main.png",
          "imageWidth": 320,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
